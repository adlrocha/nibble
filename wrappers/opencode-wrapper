#!/bin/bash
# Wrapper for OpenCode CLI to track tasks in nibble
# This wrapper transparently intercepts opencode commands and reports to nibble

# Find the original opencode binary
OPENCODE_BIN=$(which -a opencode | grep -v "$(readlink -f "$0")" | head -n 1)

if [ -z "$OPENCODE_BIN" ]; then
    echo "Error: Could not find original opencode binary" >&2
    exit 1
fi

# Generate unique task ID
TASK_ID=$(uuidgen)

# Capture the command arguments for the title
if [ $# -eq 0 ]; then
    TASK_TITLE="opencode (interactive)"
else
    # Truncate to 100 chars
    TASK_TITLE="opencode $*"
    TASK_TITLE="${TASK_TITLE:0:100}"
fi

# Register task as 'running' with process tracking
nibble report start "$TASK_ID" "opencode" "$PWD" "$TASK_TITLE" --pid $$ --ppid $PPID 2>/dev/null || {
    echo "Warning: Failed to register task with nibble" >&2
}

# Start background monitor to detect attention needs
nibble monitor "$TASK_ID" $$ >/dev/null 2>&1 &
MONITOR_PID=$!

# Use `script` to record opencode output into a temp file while preserving the
# PTY so the interactive TUI works correctly.  The typescript file captures all
# terminal output including ANSI escape codes; we strip those later.
OUTPUT_FILE=$(mktemp /tmp/opencode-output-XXXXXX.log)

if command -v script >/dev/null 2>&1; then
    # -q: quiet (no start/end banners)
    # -e: propagate exit code of the child command
    # -c: command to run
    # -f: flush output after each write (important for real-time capture)
    script -q -e -f -c "\"$OPENCODE_BIN\" $(printf '%q ' "$@")" "$OUTPUT_FILE"
    EXIT_CODE=$?
else
    # Fallback: run normally without output capture
    "$OPENCODE_BIN" "$@"
    EXIT_CODE=$?
fi

# Kill monitor
kill $MONITOR_PID 2>/dev/null || true

# Report completion
nibble report complete "$TASK_ID" --exit-code "$EXIT_CODE" 2>/dev/null || true

# Send Telegram notification with the last output from opencode.
# Strip ANSI escape sequences, then take the last 4096 chars.
if [ -f "$OUTPUT_FILE" ] && command -v nibble >/dev/null 2>&1; then
    # Strip ANSI codes with sed (works without perl/python)
    CLEAN_OUTPUT=$(sed 's/\x1b\[[0-9;]*[mGKHFABCDST]//g; s/\x1b\[[0-9;]*[Jn]//g; s/\r//g' "$OUTPUT_FILE" 2>/dev/null || true)

    if [ -n "$CLEAN_OUTPUT" ]; then
        nibble notify --task-id "$TASK_ID" --message "$CLEAN_OUTPUT" 2>/dev/null || true
    else
        nibble notify --task-id "$TASK_ID" --message "(no output captured)" 2>/dev/null || true
    fi
fi

# Clean up temp file
rm -f "$OUTPUT_FILE"

exit $EXIT_CODE
