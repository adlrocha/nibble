#!/bin/bash
# Wrapper for Claude Code CLI to track tasks in nibble
# Creates task and exports AGENT_TASK_ID for hooks to use
# Hooks handle: running (UserPromptSubmit), completed (Stop), exited (SessionEnd)
#
# Usage:
#   claude [args...]           -- normal interactive mode, auto-resumes last session
#                                 for the current repo (host or sandbox sessions)
#   claude --fresh [args...]   -- skip auto-resume, always start a new session
#   claude --kimi [args...]    -- use Kimi as the LLM backend (reads KIMI_BASE_URL
#                                 and KIMI_API_KEY from the environment)
#   claude --remote [args...]  -- unattended mode: skips all permission prompts so
#                                 you can interact purely via Telegram

# nibble binary location
AGENT_INBOX="${NIBBLE_BIN:-$HOME/.local/bin/nibble}"

# Find the original claude binary
CLAUDE_BIN=$(which -a claude | grep -v "$(readlink -f "$0")" | head -n 1)

if [ -z "$CLAUDE_BIN" ]; then
    echo "Error: Could not find original claude binary" >&2
    exit 1
fi

# Parse wrapper-specific flags (consumed here, not passed to claude)
REMOTE_MODE=false
FRESH_MODE=false
KIMI_MODE=false
CLAUDE_ARGS=()
for arg in "$@"; do
    if [ "$arg" = "--remote" ]; then
        REMOTE_MODE=true
    elif [ "$arg" = "--fresh" ]; then
        FRESH_MODE=true
    elif [ "$arg" = "--kimi" ]; then
        KIMI_MODE=true
    else
        CLAUDE_ARGS+=("$arg")
    fi
done

# If the user already passed --continue, --resume, or --new-session don't
# inject our own session flags — honour their explicit intent.
USER_HAS_SESSION_FLAG=false
for arg in "${CLAUDE_ARGS[@]}"; do
    case "$arg" in
        --continue|--resume|--new-session) USER_HAS_SESSION_FLAG=true ;;
    esac
done

# Generate unique task ID and export for hooks
export AGENT_TASK_ID=$(uuidgen)

# Get repo info if in a git repository
REPO_NAME=""
REPO_BRANCH=""
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    REPO_NAME=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null)
    REPO_BRANCH=$(git branch --show-current 2>/dev/null)
fi

# Build task title with repo/directory info
if [ -n "$REPO_NAME" ]; then
    # In a git repo - show repo name and branch
    TASK_TITLE="[$REPO_NAME"
    [ -n "$REPO_BRANCH" ] && TASK_TITLE="$TASK_TITLE:$REPO_BRANCH"
    TASK_TITLE="$TASK_TITLE]"
else
    # Not in a git repo - show directory name
    DIR_NAME=$(basename "$PWD")
    TASK_TITLE="[$DIR_NAME]"
fi

# Truncate to 100 chars
TASK_TITLE="${TASK_TITLE:0:100}"

# Build extra flags for report start
EXTRA_FLAGS=""
# Pass zellij pane ID if running inside zellij
if [ -n "$ZELLIJ" ] && [ -n "$ZELLIJ_PANE_ID" ]; then
    EXTRA_FLAGS="$EXTRA_FLAGS --zellij-pane-id $ZELLIJ_PANE_ID"
fi

# ── Session continuation ───────────────────────────────────────────────────────
# Auto-detect the most recent Claude session for the current working directory
# (mirrors the logic in cmd_sandbox_spawn). This lets a host session continue
# a conversation that was started in a sandbox, and vice-versa.
#
# Claude stores sessions under ~/.claude/projects/<encoded-path>/*.jsonl where
# the path is the absolute CWD with every '/' replaced by '-'.
#
# Skipped when:
#   - --fresh flag was passed
#   - user already supplied --continue / --resume / --new-session
#   - no prior session exists for this directory
SESSION_RESUME_FLAG=()
if [ "$FRESH_MODE" = false ] && [ "$USER_HAS_SESSION_FLAG" = false ]; then
    ABS_PATH=$(realpath "$PWD" 2>/dev/null || echo "$PWD")
    # Replace every '/' with '-' (leading slash becomes a leading dash)
    ENCODED_PATH="${ABS_PATH//\//-}"
    SESSION_DIR="$HOME/.claude/projects/$ENCODED_PATH"

    if [ -d "$SESSION_DIR" ]; then
        # Pick the .jsonl file with the most recent modification time
        LATEST_SESSION=$(ls -t "$SESSION_DIR"/*.jsonl 2>/dev/null | head -1)
        if [ -n "$LATEST_SESSION" ]; then
            SESSION_ID=$(basename "$LATEST_SESSION" .jsonl)
            SESSION_RESUME_FLAG=(--resume "$SESSION_ID")
        fi
    fi
    # If no session found for this directory, start fresh — do NOT fall back to
    # --continue, which resumes the last global session regardless of repo.
fi

# ── Kimi backend ──────────────────────────────────────────────────────────────
# When --kimi is passed, override ANTHROPIC_BASE_URL and ANTHROPIC_API_KEY with
# the values from KIMI_BASE_URL / KIMI_API_KEY (set in your shell config alongside
# the claude-kimi alias). This lets a single session switch provider without
# touching the global environment.
if [ "$KIMI_MODE" = true ]; then
    if [ -z "$KIMI_BASE_URL" ] || [ -z "$KIMI_API_KEY" ]; then
        echo "Error: --kimi requires KIMI_BASE_URL and KIMI_API_KEY to be set" >&2
        exit 1
    fi
    export ANTHROPIC_BASE_URL="$KIMI_BASE_URL"
    export ANTHROPIC_API_KEY="$KIMI_API_KEY"
fi

# Register task as 'running'
# shellcheck disable=SC2086
nibble report start "$AGENT_TASK_ID" "claude_code" "$PWD" "$TASK_TITLE" \
    --pid $$ --ppid $PPID $EXTRA_FLAGS 2>/dev/null || true

# Run claude - hooks handle status updates
if [ "$REMOTE_MODE" = true ]; then
    # Unattended mode: skip all permission prompts so the session can run
    # without keyboard interaction. Interact via Telegram Reply instead.
    exec "$CLAUDE_BIN" --dangerously-skip-permissions "${SESSION_RESUME_FLAG[@]}" "${CLAUDE_ARGS[@]}"
else
    exec "$CLAUDE_BIN" "${SESSION_RESUME_FLAG[@]}" "${CLAUDE_ARGS[@]}"
fi
